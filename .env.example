# 테스트 대상 사이트 / 자격증명 (실제 값은 .env 에 작성, .env 는 커밋 금지)
# 사용법: 이 파일을 .env 로 복사한 뒤 값을 채우세요.

# 대상 사이트 기본 URL (테스트 케이스의 {{TEST_BASE_URL}} 에 치환됨)
TEST_BASE_URL=https://example.com

# 로그인 자격증명 (테스트 케이스의 {{TEST_USERNAME}} / {{TEST_PASSWORD}} 에 치환됨)
TEST_USERNAME=
TEST_PASSWORD=

# (선택) 케이스가 추가 변수를 요구하면 여기에 정의
# TEST_OTP_SECRET=
